<?xml version="1.0" encoding="utf-8"?>
<!--
  App icon foreground — medical clipboard + red/blue capsule pill style.
  Viewport: 108×108 dp.  Safe zone (guaranteed visible): 18–90 dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── 1. Clipboard board (silver/gray rounded-rect frame) ──────────── -->
    <path android:pathData="M22,27 Q22,22 27,22 L81,22 Q86,22 86,27 L86,96 Q86,100 81,100 L27,100 Q22,100 22,96 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="22" android:startY="22"
                android:endX="86" android:endY="100">
                <item android:offset="0"   android:color="#FFD8D8D8"/>
                <item android:offset="0.6" android:color="#FFBBBBBB"/>
                <item android:offset="1"   android:color="#FF999999"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── 2. Back paper page (depth effect) ─────────────────────────────── -->
    <path android:fillColor="#FFE4E4E4"
        android:pathData="M27,43 L81,43 L81,98 L27,98 Z"/>

    <!-- ── 3. Front paper page (white) ───────────────────────────────────── -->
    <path android:fillColor="#FFFFFFFF"
        android:pathData="M25,41 Q25,39 27,39 L81,39 Q83,39 83,41 L83,97 L25,97 Z"/>

    <!-- ── 4. Red margin line ─────────────────────────────────────────────── -->
    <path android:fillColor="#FFFFB3B3"
        android:pathData="M34,43 L35.4,43 L35.4,96 L34,96 Z"/>

    <!-- ── 5. Blue horizontal ruled lines ────────────────────────────────── -->
    <path android:fillColor="#FFBBDEFB"
        android:pathData="M29,50 L79,50 L79,51.2 L29,51.2 Z
                          M29,57 L79,57 L79,58.2 L29,58.2 Z
                          M29,64 L79,64 L79,65.2 L29,65.2 Z"/>

    <!-- ── 6. DATE: field label (dark gray short bar) ────────────────────── -->
    <path android:fillColor="#FF757575"
        android:pathData="M37,45.5 L55,45.5 L55,47 L37,47 Z"/>
    <!-- DATE field value underline -->
    <path android:fillColor="#FFCCCCCC"
        android:pathData="M57,46 L70,46 L70,47 L57,47 Z"/>

    <!-- ── 7. PATIENT: field label ────────────────────────────────────────── -->
    <path android:fillColor="#FF757575"
        android:pathData="M37,52 L63,52 L63,53.5 L37,53.5 Z"/>
    <!-- PATIENT value underline -->
    <path android:fillColor="#FFCCCCCC"
        android:pathData="M65,52.5 L70,52.5 L70,53.5 L65,53.5 Z"/>

    <!-- ── 8. LOG: field label ────────────────────────────────────────────── -->
    <path android:fillColor="#FF757575"
        android:pathData="M37,58.5 L50,58.5 L50,60 L37,60 Z"/>

    <!-- ── 9. AM checkbox (hollow square outline) ────────────────────────── -->
    <path android:fillColor="#00000000"
        android:strokeColor="#FF9E9E9E"
        android:strokeWidth="1.2"
        android:pathData="M68,44 L73,44 L73,49 L68,49 Z"/>
    <!-- AM text bar -->
    <path android:fillColor="#FF9E9E9E"
        android:pathData="M74.5,45 L78,45 L78,48 L74.5,48 Z"/>

    <!-- ── 10. PM checkbox (hollow square outline) ───────────────────────── -->
    <path android:fillColor="#00000000"
        android:strokeColor="#FF9E9E9E"
        android:strokeWidth="1.2"
        android:pathData="M68,51 L73,51 L73,56 L68,56 Z"/>
    <!-- PM text bar -->
    <path android:fillColor="#FF9E9E9E"
        android:pathData="M74.5,52 L78,52 L78,55 L74.5,55 Z"/>

    <!-- ── 11. Metal clip body (silver gradient) ─────────────────────────── -->
    <path android:pathData="M40,15 Q40,12 43,12 L65,12 Q68,12 68,15 L68,40 L40,40 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="40" android:startY="12"
                android:endX="68" android:endY="40">
                <item android:offset="0"   android:color="#FFEEEEEE"/>
                <item android:offset="0.35" android:color="#FF888888"/>
                <item android:offset="0.65" android:color="#FFAAAAAA"/>
                <item android:offset="1"   android:color="#FFD0D0D0"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── 12. Clip spring coil detail ───────────────────────────────────── -->
    <path android:fillColor="#FF555555"
        android:pathData="M43,12 L65,12 L65,13.5 L43,13.5 Z"/>
    <path android:fillColor="#FF999999"
        android:pathData="M44,13.5 L64,13.5 L64,15 L44,15 Z"/>

    <!-- ── 13. Pill — left red half ──────────────────────────────────────── -->
    <!--  Capsule geometry: y=67–89 (h=22, r=11),  x=28–80 (w=52)
          Left cap centre (39,78); divider at x=54; right cap centre (69,78).
          Left red path: from top-centre, arc around left cap, back to bottom-centre. -->
    <path android:pathData="M54,67 L39,67 A11,11 0 0,0 39,89 L54,89 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="28" android:startY="67"
                android:endX="54"  android:endY="89">
                <item android:offset="0"   android:color="#FFFFCDD2"/>
                <item android:offset="0.45" android:color="#FFF44336"/>
                <item android:offset="1"   android:color="#FFB71C1C"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── 14. Pill — right blue half ────────────────────────────────────── -->
    <path android:pathData="M54,67 L69,67 A11,11 0 0,1 69,89 L54,89 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="54" android:startY="67"
                android:endX="80"  android:endY="89">
                <item android:offset="0"   android:color="#FFBBDEFB"/>
                <item android:offset="0.45" android:color="#FF42A5F5"/>
                <item android:offset="1"   android:color="#FF1565C0"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── 15. Pill centre seam (white divider line) ─────────────────────── -->
    <path android:fillColor="#FFFFFFFF"
        android:pathData="M53.1,66 L54.9,66 L54.9,90 L53.1,90 Z"/>

    <!-- ── 16. Pill glossy highlight (top shine) ─────────────────────────── -->
    <path android:pathData="M39,67 Q54,61 69,67 Q61,64 54,64 Q47,64 39,67 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="39" android:startY="61"
                android:endX="69"  android:endY="70">
                <item android:offset="0" android:color="#99FFFFFF"/>
                <item android:offset="1" android:color="#00FFFFFF"/>
            </gradient>
        </aapt:attr>
    </path>

</vector>