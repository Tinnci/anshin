<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome icon layer — Android 13+ themed icons.
  Simplified silhouette: clipboard frame + metal clip + capsule pill.
  The system applies its own tint; actual colour here doesn't matter.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Clipboard frame (outer shape with inner paper cut-out via evenOdd) -->
    <path
        android:fillColor="#FF000000"
        android:fillType="evenOdd"
        android:pathData="M22,27 Q22,22 27,22 L81,22 Q86,22 86,27 L86,96 Q86,100 81,100 L27,100 Q22,100 22,96 Z
                          M25,39 L83,39 L83,97 L25,97 Z"/>

    <!-- Metal clip -->
    <path
        android:fillColor="#FF000000"
        android:pathData="M37,15 Q37,12 40,12 L68,12 Q71,12 71,15 L71,40 L37,40 Z"/>

    <!-- Pill — left half (semicircle cap + rectangle) -->
    <path
        android:fillColor="#FF000000"
        android:pathData="M54,65 L39,65 A12,12 0 0,0 39,89 L54,89 Z"/>

    <!-- Pill — right half -->
    <path
        android:fillColor="#FF000000"
        android:pathData="M54,65 L69,65 A12,12 0 0,1 69,89 L54,89 Z"/>

    <!-- Pill centre seam (white gap gives split-capsule look in monochrome) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:pathData="M54,64 L54,90"/>

</vector>